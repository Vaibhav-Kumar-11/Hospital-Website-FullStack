# Copy this file to .env and fill in real values for your environment.
# This file is only documentation -- Django does not load .env automatically
# in this project (no python-dotenv is used); set these as real environment
# variables in your shell or in Render's dashboard.

# Django secret key. Generate a real random value for production.
SECRET_KEY=

# Full database connection string, e.g. from Supabase:
# postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# Comma-separated list of allowed frontend origins for CORS, e.g.:
# https://mediguide.netlify.app,http://localhost:5173
CORS_ALLOWED_ORIGINS=

# Set to any non-empty value (e.g. "true") when deployed on Render.
# Render sets this automatically -- you normally don't set it yourself.
RENDER=
